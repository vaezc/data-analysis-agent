# ============================================================
# LLM Provider 配置
#
# 把本文件复制为 .env.local 填入真实值。本地启动时 Next.js 自动加载。
# 部署到 Vercel 时，在项目设置 → Environment Variables 里逐个添加。
# ============================================================

# Provider 选择：deepseek | openai | claude
LLM_PROVIDER=deepseek

# API Key
#   - DeepSeek 控制台：https://platform.deepseek.com/
#   - OpenAI 控制台：https://platform.openai.com/api-keys
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 模型名（可选覆盖；默认 deepseek-v4-flash）
#   - deepseek-v4-flash：快速、性价比高，默认
#   - deepseek-v4-pro：高推理强度，复杂任务用
#   - 旧名 deepseek-chat / deepseek-reasoner 在 2026-07-24 弃用
LLM_MODEL=deepseek-v4-flash
